fs::dir_tree(".")
# Dentro del proyecto R_shiny_statml en RStudio
golem::create_golem(".", overwrite = TRUE)
golem::create_golem(".", package.name = "StatML", overwrite = TRUE)
# Crear directorios
dir.create("R")
dir.create("inst/app/www", recursive = TRUE)
dir.create("man")
# Crear NAMESPACE vacío
writeLines("# Generated by roxygen2", "NAMESPACE")
fs::dir_tree(".")
library(devtools)
devtools::document()
devtools::document()
devtools::document()
devtools::document()
readLines("NAMESPACE") |> head(30)
getwd()
library(readxl)
# Retocados
aves_conteo_paisaje   <- read_excel("aves_conteo_paisaje.xlsx")
aves_densidad_paisaje <- read_excel("aves_densidad_paisaje.xlsx")
aves_pa_paisaje       <- read_excel("aves_pa_paisaje.xlsx")
# Originales
biomasa_paisaje <- read_excel("biomasa_paisaje.xlsx")
frogs           <- read_excel("frogs.xlsx")
pie_crab        <- read_excel("pie_crab.xlsx")
# Guardar como .rda
dir.create("inst/app/data", recursive = TRUE)
save(aves_conteo_paisaje,  file = "inst/app/data/aves_conteo_paisaje.rda")
save(aves_densidad_paisaje, file = "inst/app/data/aves_densidad_paisaje.rda")
save(aves_pa_paisaje,      file = "inst/app/data/aves_pa_paisaje.rda")
save(biomasa_paisaje,      file = "inst/app/data/biomasa_paisaje.rda")
save(frogs,                file = "inst/app/data/frogs.rda")
save(pie_crab,             file = "inst/app/data/pie_crab.rda")
# Borrar los xlsx
file.remove(c("aves_conteo_paisaje.xlsx", "aves_densidad_paisaje.xlsx",
"aves_pa_paisaje.xlsx", "biomasa_paisaje.xlsx",
"frogs.xlsx", "pie_crab.xlsx"))
renv::init()
rstudioapi::openProject(".")
